# Herald Expo App -- Environment Variables
# Copy this to .env in the project root.
# EXPO_PUBLIC_ prefix = safe to bundle in the app (not secret).
# Never put API keys or private data here.

# Railway backend URL (already deployed, do not change)
EXPO_PUBLIC_API_BASE=https://web-production-b4083.up.railway.app

# Owner auth code -- miked only. Leave blank for beta testers.
# Must match HERALD_OWNER_CODE on Railway.
EXPO_PUBLIC_OWNER_CODE=

# OneSignal app ID -- paste from OneSignal dashboard when ready.
# Push works without this; just won't prompt for permission.
EXPO_PUBLIC_ONESIGNAL_APP_ID=
