{
  "expo": {
    "name": "Herald",
    "slug": "herald",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF9F7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.apexempire.herald",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Herald uses your microphone to hear your voice.",
        "NSSpeechRecognitionUsageDescription": "Herald uses speech recognition to understand you.",
        "NSCalendarsUsageDescription": "Herald reads your calendar to remember important appointments.",
        "NSHealthShareUsageDescription": "Herald reads your health data to give you personalized insights."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF9F7"
      },
      "package": "ai.apexempire.herald",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-calendar",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Herald uses your location for weather and local info.",
          "locationWhenInUsePermission": "Herald uses your location for weather and local info."
        }
      ],
      "expo-sqlite",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Herald uses your microphone to hear your voice.",
          "speechRecognitionPermission": "Herald uses speech recognition to understand you.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      [
        "react-native-health-connect",
        {
          "permissions": [
            "android.permission.health.READ_STEPS",
            "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
            "android.permission.health.READ_HEART_RATE",
            "android.permission.health.READ_SLEEP"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1A9B8A",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraPropertiesEntries": {},
            "manifestQueries": {
              "packages": [
                "com.ubercab",
                "me.lyft.android",
                "com.doordash.consumer",
                "com.ubercab.eats",
                "com.grubhub.android",
                "com.instacart.client",
                "com.starbucks.mobilecard",
                "com.chipotle.ordering",
                "com.chilifresh.chilis",
                "com.walmart.android",
                "com.target.ui",
                "com.costco.costcomobile",
                "com.aa.android",
                "com.southwest.airlines",
                "com.united.mobile.android",
                "com.hilton.android.hhonors",
                "com.ihg.apps.android",
                "com.hertz.mobile.android",
                "com.ehi.enterprise",
                "com.avis.androidapp",
                "com.budget.android",
                "com.nationalcar",
                "com.hyatt.android",
                "com.hulu.plus",
                "com.disney.disneyplus",
                "com.hbo.hbonow",
                "com.peacocktv.peacockandroid",
                "com.cbs.ott",
                "com.espn.score_center",
                "com.cvs.launchers.cvs",
                "com.walgreens.riteaid.mobile",
                "com.goodrx",
                "com.chase.sig.android",
                "com.infonow.bofa",
                "com.wf.wellsfargomobile",
                "com.americanexpress.android.acctsvcs.us",
                "com.robinhood.android",
                "com.fidelity.android",
                "com.schwab.mobile",
                "com.venmo",
                "com.paypal.android.p2pmobile",
                "com.zellepay.zelle",
                "com.audible.application",
                "com.amazon.kindle",
                "com.facebook.katana",
                "org.aarp.aarpnow",
                "com.google.android.apps.photos",
                "com.sec.android.gallery3d",
                "com.samsung.android.clockpackage"
              ]
            }
          }
        }
      ]
    ],
    "scheme": "herald",
    "extra": {
      "eas": {
        "projectId": "8a15ab41-fe80-424c-b68f-53330f90026c"
      }
    }
  }
}
